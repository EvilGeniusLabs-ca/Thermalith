<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Thermalith.App.ViewModels"
        xmlns:ed="clr-namespace:Thermalith.App.ViewModels.Editors"
        xmlns:views="clr-namespace:Thermalith.App.Views"
        x:Class="Thermalith.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Icon="/Assets/thermalith-256.png"
        Width="1200" Height="780"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Grid.frow">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="Grid.frow > TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#888" />
        </Style>
        <Style Selector="ComboBox.fld">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- Menu (§7.1) -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Name="MiNew" Header="_New" Command="{Binding NewCommand}" />
                <MenuItem Name="MiOpen" Header="_Open…" Command="{Binding OpenCommand}" />
                <MenuItem Name="MiRecent" Header="Open _Recent" IsEnabled="{Binding HasRecentFiles}" />
                <Separator />
                <MenuItem Name="MiSave" Header="_Save" Command="{Binding SaveCommand}" />
                <MenuItem Name="MiSaveAs" Header="Save _As…" Command="{Binding SaveAsCommand}" />
                <Separator />
                <MenuItem Name="MiQuit" Header="_Quit" Command="{Binding QuitCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Name="MiUndo" Header="_Undo" Command="{Binding UndoCommand}" />
                <MenuItem Name="MiRedo" Header="_Redo" Command="{Binding RedoCommand}" />
                <Separator />
                <MenuItem Name="MiCut" Header="Cu_t" Command="{Binding CutCommand}" />
                <MenuItem Name="MiCopy" Header="_Copy" Command="{Binding CopyCommand}" />
                <MenuItem Name="MiPaste" Header="_Paste" Command="{Binding PasteCommand}" />
                <MenuItem Name="MiDuplicate" Header="Du_plicate" Command="{Binding DuplicateCommand}" />
                <Separator />
                <MenuItem Name="MiDelete" Header="_Delete" Command="{Binding DeleteCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Name="MiZoomIn" Header="Zoom _In" Command="{Binding ZoomInCommand}" />
                <MenuItem Name="MiZoomOut" Header="Zoom _Out" Command="{Binding ZoomOutCommand}" />
                <MenuItem Name="MiZoomFit" Header="Zoom to _Fit" Command="{Binding ZoomFitCommand}" />
                <Separator />
                <MenuItem Header="Show _Grid" ToggleType="CheckBox" IsChecked="{Binding Editor.ShowGrid, Mode=TwoWay}" />
                <MenuItem Header="_Snap to Grid" ToggleType="CheckBox" IsChecked="{Binding Editor.SnapEnabled, Mode=TwoWay}" />
                <MenuItem Header="Show _Printable Area" ToggleType="CheckBox" IsChecked="{Binding Editor.ShowSafeArea, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Header="_Insert">
                <MenuItem Header="_Text" Command="{Binding InsertCommand}" CommandParameter="text" />
                <MenuItem Header="_Barcode" Command="{Binding InsertCommand}" CommandParameter="barcode" />
                <MenuItem Header="_QR Code" Command="{Binding InsertCommand}" CommandParameter="qr" />
                <MenuItem Header="_Serial" Command="{Binding InsertCommand}" CommandParameter="serial" />
                <MenuItem Header="_Date / Time" Command="{Binding InsertCommand}" CommandParameter="datetime" />
                <MenuItem Header="S_hape" Command="{Binding InsertCommand}" CommandParameter="shape" />
                <MenuItem Header="_Image" Command="{Binding InsertCommand}" CommandParameter="image" />
                <MenuItem Header="Ta_ble" Command="{Binding InsertCommand}" CommandParameter="table" />
            </MenuItem>
            <MenuItem Header="_Arrange">
                <MenuItem Name="MiGroup" Header="_Group" Command="{Binding GroupCommand}" />
                <MenuItem Name="MiUngroup" Header="_Ungroup" Command="{Binding UngroupCommand}" />
                <Separator />
                <MenuItem Header="Bring to _Front" Command="{Binding BringToFrontCommand}" />
                <MenuItem Header="Bring _Forward" Command="{Binding BringForwardCommand}" />
                <MenuItem Header="Send _Backward" Command="{Binding SendBackwardCommand}" />
                <MenuItem Header="Send to _Back" Command="{Binding SendToBackCommand}" />
                <Separator />
                <MenuItem Header="_Align">
                    <MenuItem Header="Left" Command="{Binding AlignLeftCommand}" />
                    <MenuItem Header="Center" Command="{Binding AlignCenterHCommand}" />
                    <MenuItem Header="Right" Command="{Binding AlignRightCommand}" />
                    <Separator />
                    <MenuItem Header="Top" Command="{Binding AlignTopCommand}" />
                    <MenuItem Header="Middle" Command="{Binding AlignMiddleVCommand}" />
                    <MenuItem Header="Bottom" Command="{Binding AlignBottomCommand}" />
                </MenuItem>
                <MenuItem Header="_Distribute">
                    <MenuItem Header="Horizontally" Command="{Binding DistributeHCommand}" />
                    <MenuItem Header="Vertically" Command="{Binding DistributeVCommand}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Printer">
                <MenuItem Header="_Refresh Ports" Command="{Binding Printer.RefreshPortsCommand}" />
                <MenuItem Header="_Connect" Command="{Binding Printer.ConnectCommand}" />
                <MenuItem Header="_Disconnect" Command="{Binding Printer.DisconnectCommand}" />
                <Separator />
                <MenuItem Header="Refresh _Status" Command="{Binding Printer.RefreshStatusCommand}" />
                <MenuItem Header="_Print" Command="{Binding Printer.PrintCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Thermalith" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#202020" Padding="6,4">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="New" Command="{Binding NewCommand}" />
                    <Button Content="Open" Command="{Binding OpenCommand}" />
                    <Button Content="Save" Command="{Binding SaveCommand}" />
                    <Rectangle Width="1" Fill="#444" Margin="4,0" />
                    <Button Content="Undo" Command="{Binding UndoCommand}" />
                    <Button Content="Redo" Command="{Binding RedoCommand}" />
                    <Rectangle Width="1" Fill="#444" Margin="4,0" />
                    <Button Content="−" Command="{Binding ZoomOutCommand}" />
                    <Button Content="Fit" Command="{Binding ZoomFitCommand}" />
                    <Button Content="+" Command="{Binding ZoomInCommand}" />
                </StackPanel>
                <!-- Connected printer + remaining labels (from the RFID roll). -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,0,4,0">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                             Fill="{Binding Printer.IsConnected, Converter={StaticResource ConnDot}}" />
                    <TextBlock Text="{Binding Printer.LoadedRollText}" Foreground="#BBB" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#202020" Padding="8,3">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="{Binding Editor.StatusText}" Foreground="#AAA" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage, UpdateSourceTrigger=PropertyChanged}" Foreground="#8AC" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding Editor.Dirty, StringFormat='dirty: {0}'}" Foreground="#777" />
            </Grid>
        </Border>

        <!-- Five-region body: layers | canvas | inspector -->
        <Grid x:Name="BodyGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: insert palette + layers -->
            <DockPanel Grid.Column="0" Background="#262626">
                <TextBlock DockPanel.Dock="Top" Text="Insert" Margin="8,6,8,2" FontWeight="Bold" Foreground="#CCC" />
                <StackPanel DockPanel.Dock="Top" Margin="6,0,6,6">
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="text">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconText}" /><TextBlock Text="Text" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="barcode">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconBarcode}" /><TextBlock Text="Barcode" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="qr">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconQr}" /><TextBlock Text="QR Code" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="serial">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconSerial}" /><TextBlock Text="Serial" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="datetime">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconDate}" /><TextBlock Text="Date / Time" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="shape">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconShape}" /><TextBlock Text="Shape" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="image">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconImage}" /><TextBlock Text="Image" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="table">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconTable}" /><TextBlock Text="Table" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Text="Elements" Margin="8,2" FontWeight="Bold" Foreground="#CCC" />
                <ListBox ItemsSource="{Binding Editor.Layers}" SelectedItem="{Binding Editor.SelectedLayer}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LayerItemViewModel">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="⛓" FontSize="11" Margin="0,0,4,0" Foreground="#E0A030"
                                           VerticalAlignment="Center" IsVisible="{Binding IsGrouped}" ToolTip.Tip="Grouped" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" />
                                <TextBlock Grid.Column="2" Text="{Binding TypeLabel}" Foreground="#777" FontSize="11" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" Background="#111" />

            <!-- CENTER: WYSIWYG canvas -->
            <ScrollViewer Grid.Column="2" Background="#3A3A3A"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Border Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Panel Name="CanvasHost"
                           Width="{Binding Editor.DisplayWidth}" Height="{Binding Editor.DisplayHeight}"
                           Background="White"
                           PointerPressed="OnCanvasPressed" PointerMoved="OnCanvasMoved" PointerReleased="OnCanvasReleased"
                           PointerWheelChanged="OnCanvasWheel">
                        <Image Source="{Binding Editor.Preview}" Stretch="Fill"
                               RenderOptions.BitmapInterpolationMode="None" />
                        <views:GridOverlay Spacing="{Binding Editor.GridSpacingDisplay}"
                                           IsVisible="{Binding Editor.ShowGrid}" />
                        <Canvas>
                            <Rectangle Canvas.Left="{Binding Editor.SafeAreaBounds.X}"
                                       Canvas.Top="{Binding Editor.SafeAreaBounds.Y}"
                                       Width="{Binding Editor.SafeAreaBounds.Width}"
                                       Height="{Binding Editor.SafeAreaBounds.Height}"
                                       Stroke="#E0A030" StrokeThickness="1" StrokeDashArray="4,3"
                                       IsVisible="{Binding Editor.HasSafeArea}" IsHitTestVisible="False" />
                            <Rectangle Name="Marquee" Stroke="#2D7DF6" StrokeThickness="1" StrokeDashArray="2,2"
                                       Fill="#202D7DF6" IsVisible="False" IsHitTestVisible="False" />
                        </Canvas>
                        <ItemsControl ItemsSource="{Binding Editor.SelectionRects}"
                                      IsVisible="{Binding Editor.HasSelection}" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter" x:DataType="vm:SelRect">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SelRect">
                                    <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                               Stroke="#2D7DF6" StrokeThickness="1.5" StrokeDashArray="3,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding Editor.SelectionHandles}"
                                      IsVisible="{Binding Editor.HasSelection}" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter" x:DataType="vm:HandleSpec">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HandleSpec">
                                    <Rectangle Width="{Binding Size}" Height="{Binding Size}"
                                               Fill="White" Stroke="#2D7DF6" StrokeThickness="1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Panel>
                </Border>
            </ScrollViewer>

            <GridSplitter Grid.Column="3" Width="4" Background="#111" />

            <!-- RIGHT: inspector + printer tabs -->
            <TabControl Grid.Column="4" Background="#262626">
                <TabItem Header="Properties">
                    <ScrollViewer Padding="8" HorizontalScrollBarVisibility="Disabled">
                        <ContentControl Content="{Binding Editor.InspectorTarget}">
                        <ContentControl.DataTemplates>

                            <DataTemplate DataType="ed:CanvasEditorViewModel">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Label" FontWeight="Bold" Margin="0,0,0,4" />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Name" /><TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Width mm" /><TextBox Grid.Column="1" Text="{Binding WidthMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Height mm" /><TextBox Grid.Column="1" Text="{Binding HeightMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="DPI" /><TextBox Grid.Column="1" Text="{Binding Dpi, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Shape" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.CanvasShape}" SelectedItem="{Binding Shape}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Corner mm" /><TextBox Grid.Column="1" Text="{Binding CornerRadiusMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Orient°" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Orientation}" SelectedItem="{Binding OrientationDeg}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Bleed mm" /><TextBox Grid.Column="1" Text="{Binding BleedMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Safe inset" /><TextBox Grid.Column="1" Text="{Binding SafeAreaInsetMm, UpdateSourceTrigger=PropertyChanged}" Watermark="none" /></Grid>
                                    <TextBlock Text="Safe area guards content against print skew (§6.1.3)." Foreground="#777" FontSize="11" TextWrapping="Wrap" Margin="0,4" />
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:TextEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Content" /><TextBox Grid.Column="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Font" /><TextBox Grid.Column="1" Text="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}" Watermark="(bundled)" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Size (pt)" /><TextBox Grid.Column="1" Text="{Binding FontSizePt, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4">
                                        <ToggleButton Classes="icon" ToolTip.Tip="Bold" IsChecked="{Binding Bold}"><TextBlock Text="B" FontWeight="Bold" /></ToggleButton>
                                        <ToggleButton Classes="icon" ToolTip.Tip="Italic" IsChecked="{Binding Italic}"><TextBlock Text="I" FontStyle="Italic" /></ToggleButton>
                                        <ToggleButton Classes="icon" ToolTip.Tip="Underline" IsChecked="{Binding Underline}"><TextBlock Text="U" TextDecorations="Underline" /></ToggleButton>
                                    </StackPanel>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Sizing" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.FontSizing}" SelectedItem="{Binding FontSizing}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Wrap" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Wrap}" SelectedItem="{Binding Wrap}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Min pt" /><TextBox Grid.Column="1" Text="{Binding MinFontSizePt, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Max pt" /><TextBox Grid.Column="1" Text="{Binding MaxFontSizePt, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Line ×" /><TextBox Grid.Column="1" Text="{Binding LineSpacing, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:BarcodeEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Symbology" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Symbology}" SelectedItem="{Binding Symbology}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Value" /><TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <CheckBox IsChecked="{Binding ShowText}" Content="Show text" Margin="0,4" />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Text pos" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.TextPosition}" SelectedItem="{Binding TextPosition}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Module mm" /><TextBox Grid.Column="1" Text="{Binding ModuleWidthMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Quiet mm" /><TextBox Grid.Column="1" Text="{Binding QuietZoneMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:QrEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Value" /><TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Encoding" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.QrEncoding}" SelectedItem="{Binding Encoding}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="EC level" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.EcLevel}" SelectedItem="{Binding EcLevel}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Module mm" /><TextBox Grid.Column="1" Text="{Binding ModuleSizeMm, UpdateSourceTrigger=PropertyChanged}" Watermark="auto" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Quiet mm" /><TextBox Grid.Column="1" Text="{Binding QuietZoneMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:SerialEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Start" /><TextBox Grid.Column="1" Text="{Binding Start, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Step" /><TextBox Grid.Column="1" Text="{Binding Step, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Pad len" /><TextBox Grid.Column="1" Text="{Binding PadLength, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Pad char" /><TextBox Grid.Column="1" Text="{Binding PadChar, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Prefix" /><TextBox Grid.Column="1" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Suffix" /><TextBox Grid.Column="1" Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:DateTimeEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Kind" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.DateKind}" SelectedItem="{Binding Kind}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Format" /><TextBox Grid.Column="1" Text="{Binding Format, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Source" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.DateSource}" SelectedItem="{Binding Source}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Fixed UTC" /><TextBox Grid.Column="1" Text="{Binding FixedValueUtc, UpdateSourceTrigger=PropertyChanged}" Watermark="ISO-8601" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:ShapeEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Shape" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.ShapeType}" SelectedItem="{Binding ShapeType}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Stroke mm" /><TextBox Grid.Column="1" Text="{Binding StrokeWidthMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Fill" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Fill}" SelectedItem="{Binding Fill}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Corner mm" /><TextBox Grid.Column="1" Text="{Binding CornerRadiusMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:ImageEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Asset id" /><TextBox Grid.Column="1" Text="{Binding AssetId, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Fit" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Fit}" SelectedItem="{Binding Fit}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Dither" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Dither}" SelectedItem="{Binding Dither}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Threshold" /><TextBox Grid.Column="1" Text="{Binding Threshold, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <CheckBox IsChecked="{Binding Invert}" Content="Invert" Margin="0,4" />
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:TableEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Cols" /><TextBox Grid.Column="1" Text="{Binding Cols, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Rows" /><TextBox Grid.Column="1" Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="62,*"><TextBlock Text="Border mm" /><TextBox Grid.Column="1" Text="{Binding BorderWidthMm, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <CheckBox IsChecked="{Binding HeaderRow}" Content="Header row" Margin="0,4" />
                                    <TextBlock Text="Cells" Foreground="#888" Margin="0,4,0,2" />
                                    <ItemsControl ItemsSource="{Binding CellRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="ed:TableRowViewModel">
                                                <ItemsControl ItemsSource="{Binding Cells}" Margin="0,1">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="ed:TableCellViewModel">
                                                            <TextBox Width="58" Margin="1" Padding="3,1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>

                            </ContentControl.DataTemplates>
                        </ContentControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Printer">
                    <ScrollViewer Padding="8" HorizontalScrollBarVisibility="Disabled" DataContext="{Binding Printer}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Connection" FontWeight="Bold" Foreground="#CCC" />
                            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Ports}"
                                      SelectedItem="{Binding SelectedPort}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PortItem">
                                        <TextBlock Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Scan" Command="{Binding RefreshPortsCommand}" />
                                <Button Content="Connect" Command="{Binding ConnectCommand}" />
                                <Button Content="Disconnect" Command="{Binding DisconnectCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding ConnectionInfo, UpdateSourceTrigger=PropertyChanged}" Foreground="#AAA" TextWrapping="Wrap" />

                            <Separator />
                            <TextBlock Text="Status" FontWeight="Bold" Foreground="#CCC" />
                            <TextBlock Text="{Binding StatusInfo, UpdateSourceTrigger=PropertyChanged}" Foreground="#AAA" TextWrapping="Wrap" />
                            <Button Content="Refresh status" Command="{Binding RefreshStatusCommand}" HorizontalAlignment="Left" />

                            <Separator />
                            <TextBlock Text="Print" FontWeight="Bold" Foreground="#CCC" />
                            <Grid ColumnDefinitions="62,*" Margin="0,2">
                                <TextBlock Text="Density" Foreground="#888" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Slider Width="150" Minimum="{Binding DensityMin}" Maximum="{Binding DensityMax}"
                                            Value="{Binding Density}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                    <TextBlock Text="{Binding Density, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Foreground="#AAA" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="62,*" Margin="0,2">
                                <TextBlock Text="Label type" Foreground="#888" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding LabelTypes}" SelectedItem="{Binding SelectedLabelType}" />
                            </Grid>
                            <Grid ColumnDefinitions="62,*" Margin="0,2">
                                <TextBlock Text="Copies" Foreground="#888" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid ColumnDefinitions="62,*" Margin="0,2">
                                <TextBlock Text="Offset X px" Foreground="#888" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid ColumnDefinitions="62,*" Margin="0,2">
                                <TextBlock Text="Offset Y px" Foreground="#888" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Button Content="Print" Command="{Binding PrintCommand}" HorizontalAlignment="Stretch" Margin="0,6" />

                            <TextBlock Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}" Foreground="#8AC" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

    </DockPanel>

</Window>
