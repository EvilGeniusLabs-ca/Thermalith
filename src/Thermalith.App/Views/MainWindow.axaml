<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Thermalith.App.ViewModels"
        xmlns:ed="clr-namespace:Thermalith.App.ViewModels.Editors"
        xmlns:views="clr-namespace:Thermalith.App.Views"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="Thermalith.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Icon="/Assets/thermalith-256.png"
        Cursor="{Binding Printer.IsBusy, Converter={StaticResource BusyCursor}}"
        Width="1200" Height="780"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Grid.frow">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="Grid.frow > TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#888" />
        </Style>
        <Style Selector="ComboBox.fld">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- Menu (§7.1) -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Name="MiNew" Header="_New" Command="{Binding NewCommand}" />
                <MenuItem Name="MiOpen" Header="_Open…" Command="{Binding OpenCommand}" />
                <MenuItem Name="MiRecent" Header="Open _Recent" IsEnabled="{Binding HasRecentFiles}" />
                <Separator />
                <MenuItem Name="MiSave" Header="_Save" Command="{Binding SaveCommand}" />
                <MenuItem Name="MiSaveAs" Header="Save _As…" Command="{Binding SaveAsCommand}" />
                <Separator />
                <MenuItem Name="MiQuit" Header="_Quit" Command="{Binding QuitCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Name="MiUndo" Header="_Undo" Command="{Binding UndoCommand}" />
                <MenuItem Name="MiRedo" Header="_Redo" Command="{Binding RedoCommand}" />
                <Separator />
                <MenuItem Name="MiCut" Header="Cu_t" Command="{Binding CutCommand}" />
                <MenuItem Name="MiCopy" Header="_Copy" Command="{Binding CopyCommand}" />
                <MenuItem Name="MiPaste" Header="_Paste" Command="{Binding PasteCommand}" />
                <MenuItem Name="MiDuplicate" Header="Du_plicate" Command="{Binding DuplicateCommand}" />
                <Separator />
                <MenuItem Name="MiDelete" Header="_Delete" Command="{Binding DeleteCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Name="MiZoomIn" Header="Zoom _In" Command="{Binding ZoomInCommand}" />
                <MenuItem Name="MiZoomOut" Header="Zoom _Out" Command="{Binding ZoomOutCommand}" />
                <MenuItem Name="MiZoomFit" Header="Zoom to _Fit" Command="{Binding ZoomFitCommand}" />
                <Separator />
                <MenuItem Header="Show _Grid" ToggleType="CheckBox" IsChecked="{Binding Editor.ShowGrid, Mode=TwoWay}" />
                <MenuItem Header="_Snap to Grid" ToggleType="CheckBox" IsChecked="{Binding Editor.SnapEnabled, Mode=TwoWay}" />
                <MenuItem Header="Show _Printable Area" ToggleType="CheckBox" IsChecked="{Binding Editor.ShowSafeArea, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="S_mooth Preview" ToggleType="CheckBox" IsChecked="{Binding Editor.SmoothPreview, Mode=TwoWay}"
                          ToolTip.Tip="Show the smooth grayscale preview (anti-aliased) instead of the exact 1-bit print raster" />
            </MenuItem>
            <MenuItem Header="_Insert">
                <MenuItem Header="_Text" Command="{Binding InsertCommand}" CommandParameter="text" />
                <MenuItem Header="_Barcode" Command="{Binding InsertCommand}" CommandParameter="barcode" />
                <MenuItem Header="_QR Code" Command="{Binding InsertCommand}" CommandParameter="qr" />
                <MenuItem Header="_Serial" Command="{Binding InsertCommand}" CommandParameter="serial" />
                <MenuItem Header="_Date / Time" Command="{Binding InsertCommand}" CommandParameter="datetime" />
                <MenuItem Header="S_hape" Command="{Binding InsertCommand}" CommandParameter="shape" />
                <MenuItem Header="_Image" Command="{Binding InsertCommand}" CommandParameter="image" />
                <MenuItem Header="Ta_ble" Command="{Binding InsertCommand}" CommandParameter="table" />
            </MenuItem>
            <MenuItem Header="_Arrange">
                <MenuItem Name="MiGroup" Header="_Group" Command="{Binding GroupCommand}" />
                <MenuItem Name="MiUngroup" Header="_Ungroup" Command="{Binding UngroupCommand}" />
                <Separator />
                <MenuItem Header="Bring to _Front" Command="{Binding BringToFrontCommand}" />
                <MenuItem Header="Bring _Forward" Command="{Binding BringForwardCommand}" />
                <MenuItem Header="Send _Backward" Command="{Binding SendBackwardCommand}" />
                <MenuItem Header="Send to _Back" Command="{Binding SendToBackCommand}" />
                <Separator />
                <MenuItem Header="_Align">
                    <MenuItem Header="Left" Command="{Binding AlignLeftCommand}" />
                    <MenuItem Header="Center" Command="{Binding AlignCenterHCommand}" />
                    <MenuItem Header="Right" Command="{Binding AlignRightCommand}" />
                    <Separator />
                    <MenuItem Header="Top" Command="{Binding AlignTopCommand}" />
                    <MenuItem Header="Middle" Command="{Binding AlignMiddleVCommand}" />
                    <MenuItem Header="Bottom" Command="{Binding AlignBottomCommand}" />
                </MenuItem>
                <MenuItem Header="_Distribute">
                    <MenuItem Header="Horizontally" Command="{Binding DistributeHCommand}" />
                    <MenuItem Header="Vertically" Command="{Binding DistributeVCommand}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Center on _Label">
                    <MenuItem Header="_Horizontally" Command="{Binding CenterOnLabelHCommand}" />
                    <MenuItem Header="_Vertically" Command="{Binding CenterOnLabelVCommand}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Printer">
                <MenuItem Header="_Refresh Ports" Command="{Binding Printer.RefreshPortsCommand}" />
                <MenuItem Header="_Connect" Command="{Binding Printer.ConnectCommand}" />
                <MenuItem Header="_Disconnect" Command="{Binding Printer.DisconnectCommand}" />
                <Separator />
                <MenuItem Header="Refresh _Status" Command="{Binding Printer.RefreshStatusCommand}" />
                <MenuItem Header="Change _Labels" Command="{Binding Printer.ChangeLabelsCommand}" />
                <MenuItem Header="_Print" Command="{Binding Printer.PrintCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Thermalith" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#202020" Padding="6,4">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="New" Command="{Binding NewCommand}" />
                    <Button Content="Open" Command="{Binding OpenCommand}" />
                    <Button Content="Save" Command="{Binding SaveCommand}" />
                    <Rectangle Width="1" Fill="#444" Margin="4,0" />
                    <Button Content="Undo" Command="{Binding UndoCommand}" />
                    <Button Content="Redo" Command="{Binding RedoCommand}" />
                    <Rectangle Width="1" Fill="#444" Margin="4,0" />
                    <Button Content="−" Command="{Binding ZoomOutCommand}" />
                    <Button Content="Fit" Command="{Binding ZoomFitCommand}" />
                    <Button Content="+" Command="{Binding ZoomInCommand}" />
                    <Rectangle Width="1" Fill="#444" Margin="4,0" />
                    <!-- Quick canvas-size edit; bound to the same canvas as the Properties panel (§C). -->
                    <TextBlock Text="W" Foreground="#888" VerticalAlignment="Center" />
                    <NumericUpDown Width="140" Value="{Binding Editor.CanvasWidthMm}" Minimum="1" FormatString="0.#"
                             VerticalAlignment="Center" ToolTip.Tip="Canvas width (mm)" />
                    <TextBlock Text="H" Foreground="#888" VerticalAlignment="Center" />
                    <NumericUpDown Width="140" Value="{Binding Editor.CanvasHeightMm}" Minimum="1" FormatString="0.#"
                             VerticalAlignment="Center" ToolTip.Tip="Canvas height (mm)" />
                    <TextBlock Text="mm" Foreground="#888" VerticalAlignment="Center" />
                </StackPanel>
                <!-- Right: connected printer + remaining labels (from the RFID roll), then Print pinned far-right. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                             Fill="{Binding Printer.IsConnected, Converter={StaticResource ConnDot}}" />
                    <TextBlock Text="{Binding Printer.LoadedRollText}" Foreground="#BBB" VerticalAlignment="Center" />
                    <Button Content="Print" Command="{Binding Printer.PrintCommand}" Classes="accent" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#202020" Padding="8,3">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="{Binding Editor.StatusText}" Foreground="#AAA" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage, UpdateSourceTrigger=PropertyChanged}" Foreground="#8AC" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding Editor.Dirty, StringFormat='dirty: {0}'}" Foreground="#777" />
            </Grid>
        </Border>

        <!-- Five-region body: layers | canvas | inspector -->
        <Grid x:Name="BodyGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: insert palette + layers -->
            <DockPanel Grid.Column="0" Background="#262626">
                <TextBlock DockPanel.Dock="Top" Text="Insert" Margin="8,6,8,2" FontWeight="Bold" Foreground="#CCC" />
                <StackPanel DockPanel.Dock="Top" Margin="6,0,6,6">
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="text">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconText}" /><TextBlock Text="Text" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="barcode">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconBarcode}" /><TextBlock Text="Barcode" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="qr">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconQr}" /><TextBlock Text="QR Code" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="serial">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconSerial}" /><TextBlock Text="Serial" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="datetime">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconDate}" /><TextBlock Text="Date / Time" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="shape">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconShape}" /><TextBlock Text="Shape" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="image">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconImage}" /><TextBlock Text="Image" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Classes="insert" Command="{Binding InsertCommand}" CommandParameter="table">
                        <StackPanel Orientation="Horizontal" Spacing="8"><Path Classes="icon" Data="{StaticResource IconTable}" /><TextBlock Text="Table" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Text="Elements" Margin="8,2" FontWeight="Bold" Foreground="#CCC" />
                <ListBox ItemsSource="{Binding Editor.Layers}" SelectedItem="{Binding Editor.SelectedLayer}"
                         SelectionChanged="OnElementsListSelectionChanged"
                         PointerPressed="OnElementsListPointerPressed">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LayerItemViewModel">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                <TextBlock Text="⛓" FontSize="11" Margin="0,0,4,0" Foreground="#E0A030"
                                           VerticalAlignment="Center" IsVisible="{Binding IsGrouped}" ToolTip.Tip="Grouped" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding TypeLabel}" Foreground="#777" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,4,0" />
                                <ToggleButton Grid.Column="3" Classes="listicon" ToolTip.Tip="Visible"
                                              IsChecked="{Binding Visible}"><Path Classes="icon" Data="{StaticResource IconEye}" /></ToggleButton>
                                <ToggleButton Grid.Column="4" Classes="listicon" ToolTip.Tip="Locked"
                                              IsChecked="{Binding Locked}"><Path Classes="icon" Data="{StaticResource IconLock}" /></ToggleButton>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" Background="#111" />

            <!-- CENTER: WYSIWYG canvas, framed by mm rulers (top + left) kept in sync with zoom/scroll. -->
            <Grid Grid.Column="2" RowDefinitions="20,*" ColumnDefinitions="26,*">
                <Border Grid.Row="0" Grid.Column="0" Background="#222" />
                <views:Ruler Grid.Row="0" Grid.Column="1" x:Name="TopRuler" Orientation="Horizontal" />
                <views:Ruler Grid.Row="1" Grid.Column="0" x:Name="LeftRuler" Orientation="Vertical" />
                <ScrollViewer Grid.Row="1" Grid.Column="1" x:Name="CanvasScroll" Background="#3A3A3A"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Border Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Panel Name="CanvasHost" Focusable="True"
                           Width="{Binding Editor.DisplayWidth}" Height="{Binding Editor.DisplayHeight}"
                           Background="White"
                           PointerPressed="OnCanvasPressed" PointerMoved="OnCanvasMoved" PointerReleased="OnCanvasReleased"
                           PointerWheelChanged="OnCanvasWheel" DoubleTapped="OnCanvasDoubleTapped">
                        <Panel.ContextMenu>
                            <ContextMenu>
                                <!-- Element ops (hidden while editing table cells). -->
                                <MenuItem Header="Cut" Command="{Binding CutCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Copy" Command="{Binding CopyCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Paste" Command="{Binding PasteCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Delete" Command="{Binding DeleteCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <Separator IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Lock / Unlock" Command="{Binding ToggleLockCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Show / Hide" Command="{Binding ToggleVisibleCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <Separator IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Bring to Front" Command="{Binding BringToFrontCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Bring Forward" Command="{Binding BringForwardCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Send Backward" Command="{Binding SendBackwardCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Send to Back" Command="{Binding SendToBackCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <Separator IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Group" Command="{Binding GroupCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Ungroup" Command="{Binding UngroupCommand}" IsVisible="{Binding !Editor.InCellMode}" />
                                <MenuItem Header="Align" IsVisible="{Binding !Editor.InCellMode}">
                                    <MenuItem Header="Left" Command="{Binding AlignLeftCommand}" />
                                    <MenuItem Header="Center" Command="{Binding AlignCenterHCommand}" />
                                    <MenuItem Header="Right" Command="{Binding AlignRightCommand}" />
                                    <Separator />
                                    <MenuItem Header="Top" Command="{Binding AlignTopCommand}" />
                                    <MenuItem Header="Middle" Command="{Binding AlignMiddleVCommand}" />
                                    <MenuItem Header="Bottom" Command="{Binding AlignBottomCommand}" />
                                </MenuItem>
                                <MenuItem Header="Center on Label" IsVisible="{Binding !Editor.InCellMode}">
                                    <MenuItem Header="Horizontally" Command="{Binding CenterOnLabelHCommand}" />
                                    <MenuItem Header="Vertically" Command="{Binding CenterOnLabelVCommand}" />
                                </MenuItem>

                                <!-- Table cell ops (shown while editing table cells). -->
                                <MenuItem Header="Merge Cells" Command="{Binding CellMergeCommand}" IsVisible="{Binding Editor.InCellMode}" />
                                <MenuItem Header="Unmerge" Command="{Binding CellUnmergeCommand}" IsVisible="{Binding Editor.InCellMode}" />
                                <Separator IsVisible="{Binding Editor.InCellMode}" />
                                <MenuItem Header="Fill" IsVisible="{Binding Editor.InCellMode}">
                                    <MenuItem Header="None" Command="{Binding CellFillCommand}" CommandParameter="0" />
                                    <MenuItem Header="25%" Command="{Binding CellFillCommand}" CommandParameter="25" />
                                    <MenuItem Header="50%" Command="{Binding CellFillCommand}" CommandParameter="50" />
                                    <MenuItem Header="75%" Command="{Binding CellFillCommand}" CommandParameter="75" />
                                    <MenuItem Header="100%" Command="{Binding CellFillCommand}" CommandParameter="100" />
                                </MenuItem>
                                <MenuItem Header="Text Colour" IsVisible="{Binding Editor.InCellMode}">
                                    <MenuItem Header="Black" Command="{Binding CellTextBlackCommand}" />
                                    <MenuItem Header="White" Command="{Binding CellTextWhiteCommand}" />
                                </MenuItem>
                                <MenuItem Header="Bold" Command="{Binding CellBoldCommand}" IsVisible="{Binding Editor.InCellMode}" />
                                <MenuItem Header="Italic" Command="{Binding CellItalicCommand}" IsVisible="{Binding Editor.InCellMode}" />
                                <MenuItem Header="Align" IsVisible="{Binding Editor.InCellMode}">
                                    <MenuItem Header="Left" Command="{Binding CellAlignHCommand}" CommandParameter="left" />
                                    <MenuItem Header="Center" Command="{Binding CellAlignHCommand}" CommandParameter="center" />
                                    <MenuItem Header="Right" Command="{Binding CellAlignHCommand}" CommandParameter="right" />
                                    <Separator />
                                    <MenuItem Header="Top" Command="{Binding CellAlignVCommand}" CommandParameter="top" />
                                    <MenuItem Header="Middle" Command="{Binding CellAlignVCommand}" CommandParameter="middle" />
                                    <MenuItem Header="Bottom" Command="{Binding CellAlignVCommand}" CommandParameter="bottom" />
                                </MenuItem>
                                <Separator IsVisible="{Binding Editor.InCellMode}" />
                                <MenuItem Header="Header Row" Command="{Binding CellHeaderRowCommand}" IsVisible="{Binding Editor.InCellMode}" />
                                <MenuItem Header="Header Column" Command="{Binding CellHeaderColumnCommand}" IsVisible="{Binding Editor.InCellMode}" />
                            </ContextMenu>
                        </Panel.ContextMenu>
                        <Image Source="{Binding Editor.Preview}" Stretch="Fill"
                               RenderOptions.BitmapInterpolationMode="None" />
                        <views:GridOverlay Spacing="{Binding Editor.GridSpacingDisplay}"
                                           IsVisible="{Binding Editor.ShowGrid}" />
                        <!-- Print-area boundary is now drawn as full-span lines by PrintGuideOverlay
                             (over the whole viewport), not a box hugging the label. -->
                        <Canvas>
                            <Rectangle Name="Marquee" Stroke="#2D7DF6" StrokeThickness="1" StrokeDashArray="2,2"
                                       Fill="#202D7DF6" IsVisible="False" IsHitTestVisible="False" />
                        </Canvas>
                        <ItemsControl ItemsSource="{Binding Editor.SelectionRects}"
                                      IsVisible="{Binding Editor.HasSelection}" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter" x:DataType="vm:SelRect">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SelRect">
                                    <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                               Stroke="{Binding Locked, Converter={StaticResource LockStroke}}"
                                               StrokeThickness="1.5" StrokeDashArray="3,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding Editor.SelectionHandles}"
                                      IsVisible="{Binding Editor.HasSelection}" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter" x:DataType="vm:HandleSpec">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HandleSpec">
                                    <Rectangle Width="{Binding Size}" Height="{Binding Size}"
                                               Fill="White" Stroke="#2D7DF6" StrokeThickness="1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Table cell-edit mode: highlight for the selected cell block. -->
                        <ItemsControl ItemsSource="{Binding Editor.CellHighlights}"
                                      IsVisible="{Binding Editor.InCellMode}" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter" x:DataType="vm:SelRect">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SelRect">
                                    <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                               Fill="#332D7DF6" Stroke="#2D7DF6" StrokeThickness="1.5" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- In-place cell editor (shown over the active cell while editing). -->
                        <Canvas IsHitTestVisible="{Binding Editor.IsCellEditing}">
                            <TextBox x:Name="CellEditor" IsVisible="{Binding Editor.IsCellEditing}"
                                     Canvas.Left="{Binding Editor.CellEditorRect.X}" Canvas.Top="{Binding Editor.CellEditorRect.Y}"
                                     Width="{Binding Editor.CellEditorRect.Width}" Height="{Binding Editor.CellEditorRect.Height}"
                                     MinHeight="0" Padding="2,0" FontSize="11"
                                     Text="{Binding Editor.CellEditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="OnCellEditorKeyDown" LostFocus="OnCellEditorLostFocus" />
                        </Canvas>
                    </Panel>
                </Border>
                </ScrollViewer>
                <!-- Print-area guide lines, spanning the canvas viewport; origin/scale synced in code-behind. -->
                <views:PrintGuideOverlay Grid.Row="1" Grid.Column="1" x:Name="PrintGuide"
                                         IsVisible="{Binding Editor.ShowSafeArea}"
                                         InsetMm="{Binding Editor.SafeAreaInsetMm}"
                                         LabelWidthMm="{Binding Editor.CanvasWidthMm}"
                                         LabelHeightMm="{Binding Editor.CanvasHeightMm}" />
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" Background="#111" />

            <!-- RIGHT: inspector + printer tabs -->
            <TabControl Grid.Column="4" Background="#262626">
                <TabItem Header="Properties">
                    <ScrollViewer Padding="8" HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto" ScrollViewer.AllowAutoHide="False">
                        <StackPanel>
                        <!-- Table cell controls (mirror the right-click cell menu) — shown in cell-edit mode. -->
                        <StackPanel IsVisible="{Binding InspectorShowsCells}" Spacing="3">
                            <TextBlock Text="Table cell" FontWeight="Bold" Margin="0,0,0,2" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="Merge" Command="{Binding CellMergeCommand}" />
                                <Button Content="Unmerge" Command="{Binding CellUnmergeCommand}" />
                            </StackPanel>
                            <TextBlock Classes="section" Text="Fill" />
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <Button Content="0" Width="34" Command="{Binding CellFillCommand}" CommandParameter="0" />
                                <Button Content="25" Width="34" Command="{Binding CellFillCommand}" CommandParameter="25" />
                                <Button Content="50" Width="34" Command="{Binding CellFillCommand}" CommandParameter="50" />
                                <Button Content="75" Width="34" Command="{Binding CellFillCommand}" CommandParameter="75" />
                                <Button Content="100" Width="40" Command="{Binding CellFillCommand}" CommandParameter="100" />
                            </StackPanel>
                            <TextBlock Classes="section" Text="Text" />
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <Button Content="Black" Command="{Binding CellTextBlackCommand}" />
                                <Button Content="White" Command="{Binding CellTextWhiteCommand}" />
                                <Button Content="B" FontWeight="Bold" Command="{Binding CellBoldCommand}" />
                                <Button Content="I" FontStyle="Italic" Command="{Binding CellItalicCommand}" />
                            </StackPanel>
                            <TextBlock Classes="section" Text="Align" />
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <Button Content="L" Width="30" Command="{Binding CellAlignHCommand}" CommandParameter="left" />
                                <Button Content="C" Width="30" Command="{Binding CellAlignHCommand}" CommandParameter="center" />
                                <Button Content="R" Width="30" Command="{Binding CellAlignHCommand}" CommandParameter="right" />
                                <Rectangle Width="1" Fill="#444" Margin="3,2" />
                                <Button Content="T" Width="30" Command="{Binding CellAlignVCommand}" CommandParameter="top" />
                                <Button Content="M" Width="30" Command="{Binding CellAlignVCommand}" CommandParameter="middle" />
                                <Button Content="B" Width="30" Command="{Binding CellAlignVCommand}" CommandParameter="bottom" />
                            </StackPanel>
                            <TextBlock Classes="section" Text="Header" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="Row" Command="{Binding CellHeaderRowCommand}" />
                                <Button Content="Column" Command="{Binding CellHeaderColumnCommand}" />
                            </StackPanel>
                            <TextBlock Text="Double-click a cell to edit · Esc to exit" Foreground="#777" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <Separator Margin="0,4" />
                        </StackPanel>
                        <ContentControl Name="InspectorHost" Content="{Binding Editor.InspectorTarget}"
                                        IsVisible="{Binding !InspectorShowsCells}">
                        <ContentControl.DataTemplates>

                            <DataTemplate DataType="ed:CanvasEditorViewModel">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Label" FontWeight="Bold" Margin="0,0,0,4" />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Name" /><TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Width mm" /><NumericUpDown Grid.Column="1" Value="{Binding WidthMm}" Minimum="1" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Height mm" /><NumericUpDown Grid.Column="1" Value="{Binding HeightMm}" Minimum="1" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="DPI" /><NumericUpDown Grid.Column="1" Value="{Binding Dpi}" Minimum="50" FormatString="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Shape" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.CanvasShape}" SelectedItem="{Binding Shape}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Corner mm" /><NumericUpDown Grid.Column="1" Value="{Binding CornerRadiusMm}" Increment="0.1" Minimum="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Orient°" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Orientation}" SelectedItem="{Binding OrientationDeg}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Bleed mm" /><NumericUpDown Grid.Column="1" Value="{Binding BleedMm}" Increment="0.1" Minimum="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Safe inset" /><NumericUpDown Grid.Column="1" Value="{Binding SafeAreaInsetMm}" Increment="0.1" Minimum="0" Watermark="none" /></Grid>
                                    <TextBlock Text="Safe area guards content against print skew (§6.1.3)." Foreground="#777" FontSize="11" TextWrapping="Wrap" Margin="0,4" />
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:TextEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />

                                    <TextBlock Classes="section" Text="Content" />
                                    <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" />

                                    <TextBlock Classes="section" Text="Font" />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Font" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Fonts}" SelectedItem="{Binding SelectedFont}" /></Grid>
                                    <!-- Size + B/I/U share one row. -->
                                    <Grid Classes="frow" ColumnDefinitions="90,120,*">
                                        <TextBlock Text="Size (pt)" />
                                        <NumericUpDown Grid.Column="1" Value="{Binding FontSizePt}" Minimum="1" Maximum="500" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="3" HorizontalAlignment="Right">
                                            <ToggleButton Classes="icon" ToolTip.Tip="Bold" IsChecked="{Binding Bold}"><TextBlock Text="B" FontWeight="Bold" /></ToggleButton>
                                            <ToggleButton Classes="icon" ToolTip.Tip="Italic" IsChecked="{Binding Italic}"><TextBlock Text="I" FontStyle="Italic" /></ToggleButton>
                                            <ToggleButton Classes="icon" ToolTip.Tip="Underline" IsChecked="{Binding Underline}"><TextBlock Text="U" TextDecorations="Underline" /></ToggleButton>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Classes="section" Text="Paragraph" />
                                    <CheckBox IsChecked="{Binding AutoSize}" Content="Auto-size box to text" Margin="0,2"
                                              ToolTip.Tip="The box hugs the text (no resize handles). Turn off for a fixed box with word-wrap." />
                                    <Grid Classes="frow" ColumnDefinitions="90,*" IsEnabled="{Binding !AutoSize}"><TextBlock Text="Wrap" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Wrap}" SelectedItem="{Binding Wrap}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Line spacing" /><NumericUpDown Grid.Column="1" Value="{Binding LineSpacing}" Minimum="0" Increment="0.1" FormatString="0.0#" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:BarcodeEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Symbology" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Symbology}" SelectedItem="{Binding Symbology}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Value" /><TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <CheckBox IsChecked="{Binding ShowText}" Content="Show text" Margin="0,4" />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Text pos" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.TextPosition}" SelectedItem="{Binding TextPosition}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Module mm" /><NumericUpDown Grid.Column="1" Value="{Binding ModuleWidthMm}" Increment="0.1" Minimum="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Quiet mm" ToolTip.Tip="Blank margin on each side of the barcode, required for reliable scanning." /><NumericUpDown Grid.Column="1" Value="{Binding QuietZoneMm}" Increment="0.1" Minimum="0" ToolTip.Tip="Blank margin on each side of the barcode, required for reliable scanning." /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:QrEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Value" /><TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Encoding" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.QrEncoding}" SelectedItem="{Binding Encoding}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="EC level" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.EcLevel}" SelectedItem="{Binding EcLevel}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Module mm" /><NumericUpDown Grid.Column="1" Value="{Binding ModuleSizeMm}" Increment="0.1" Minimum="0" Watermark="auto" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Quiet mm" ToolTip.Tip="Blank margin around the code, required for reliable scanning. The gap to the selection box is the quiet zone, not a bug; 0 hugs the box but can hurt scannability." /><NumericUpDown Grid.Column="1" Value="{Binding QuietZoneMm}" Increment="0.1" Minimum="0" ToolTip.Tip="Blank margin around the code, required for reliable scanning. 0 hugs the box but can hurt scannability." /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:SerialEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Start" /><NumericUpDown Grid.Column="1" Value="{Binding Start}" Minimum="0" FormatString="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Step" /><NumericUpDown Grid.Column="1" Value="{Binding Step}" Minimum="1" FormatString="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Pad len" /><NumericUpDown Grid.Column="1" Value="{Binding PadLength}" Minimum="0" FormatString="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Pad char" /><TextBox Grid.Column="1" Text="{Binding PadChar, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Prefix" /><TextBox Grid.Column="1" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Suffix" /><TextBox Grid.Column="1" Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:DateTimeEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Kind" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.DateKind}" SelectedItem="{Binding Kind}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Format" /><TextBox Grid.Column="1" Text="{Binding Format, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Source" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.DateSource}" SelectedItem="{Binding Source}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Fixed value" /><TextBox Grid.Column="1" Text="{Binding FixedValueUtc, UpdateSourceTrigger=PropertyChanged}" Watermark="ISO-8601 UTC" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:ShapeEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Shape" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.ShapeType}" SelectedItem="{Binding ShapeType}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Stroke mm" /><NumericUpDown Grid.Column="1" Value="{Binding StrokeWidthMm}" Increment="0.1" Minimum="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Fill" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Fill}" SelectedItem="{Binding Fill}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Corner mm" /><NumericUpDown Grid.Column="1" Value="{Binding CornerRadiusMm}" Increment="0.1" Minimum="0" /></Grid>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:ImageEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Button HorizontalAlignment="Stretch" Margin="0,2"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ChooseImageCommand}"
                                            Content="Choose image…" />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Asset id" /><TextBox Grid.Column="1" Text="{Binding AssetId, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Fit" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Fit}" SelectedItem="{Binding Fit}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Dither" /><ComboBox Classes="fld" Grid.Column="1" ItemsSource="{x:Static ed:EditorOptions.Dither}" SelectedItem="{Binding Dither}" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Threshold" /><NumericUpDown Grid.Column="1" Value="{Binding Threshold}" Minimum="0" Maximum="255" FormatString="0" /></Grid>
                                    <CheckBox IsChecked="{Binding Invert}" Content="Invert" Margin="0,4" />
                                    <TextBlock Text="Transform" Foreground="#888" Margin="0,4,0,0" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Classes="icon" Command="{Binding RotateCcwCommand}" ToolTip.Tip="Rotate counter-clockwise 90°"><mi:MaterialIcon Kind="RotateLeft" Width="16" Height="16" Foreground="#D0D0D0" /></Button>
                                        <Button Classes="icon" Command="{Binding RotateCwCommand}" ToolTip.Tip="Rotate clockwise 90°"><mi:MaterialIcon Kind="RotateRight" Width="16" Height="16" Foreground="#D0D0D0" /></Button>
                                        <ToggleButton Classes="icon" IsChecked="{Binding FlipH}" ToolTip.Tip="Mirror (flip horizontal)"><mi:MaterialIcon Kind="FlipHorizontal" Width="16" Height="16" Foreground="#D0D0D0" /></ToggleButton>
                                        <ToggleButton Classes="icon" IsChecked="{Binding FlipV}" ToolTip.Tip="Flip (vertical)"><mi:MaterialIcon Kind="FlipVertical" Width="16" Height="16" Foreground="#D0D0D0" /></ToggleButton>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>

                            <DataTemplate DataType="ed:TableEditorViewModel">
                                <StackPanel Spacing="2">
                                    <views:BaseElementFields />
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Cols" /><NumericUpDown Grid.Column="1" Value="{Binding Cols}" Minimum="1" FormatString="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Rows" /><NumericUpDown Grid.Column="1" Value="{Binding Rows}" Minimum="1" FormatString="0" /></Grid>
                                    <Grid Classes="frow" ColumnDefinitions="90,*"><TextBlock Text="Line Weight" /><NumericUpDown Grid.Column="1" Value="{Binding BorderWidthMm}" Increment="0.1" Minimum="0" /></Grid>
                                    <TextBlock Text="Double-click the table to edit cells (select, type, merge, fill, header)."
                                               Foreground="#777" FontSize="11" TextWrapping="Wrap" Margin="0,6" />
                                </StackPanel>
                            </DataTemplate>

                            </ContentControl.DataTemplates>
                        </ContentControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Printer">
                    <ScrollViewer Padding="8" HorizontalScrollBarVisibility="Disabled" DataContext="{Binding Printer}">
                        <StackPanel Spacing="6">
                            <ProgressBar IsIndeterminate="True" Height="3" IsVisible="{Binding IsBusy}" />
                            <TextBlock Text="Connection" FontWeight="Bold" Foreground="#CCC" />
                            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Ports}"
                                      SelectedItem="{Binding SelectedPort}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PortItem">
                                        <TextBlock Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Scan" Command="{Binding RefreshPortsCommand}" />
                                <Button Content="Connect" Command="{Binding ConnectCommand}" />
                                <Button Content="Disconnect" Command="{Binding DisconnectCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding ConnectionInfo, UpdateSourceTrigger=PropertyChanged}" Foreground="#AAA" TextWrapping="Wrap" />

                            <Separator />
                            <TextBlock Text="Status" FontWeight="Bold" Foreground="#CCC" />
                            <TextBlock Text="{Binding StatusInfo, UpdateSourceTrigger=PropertyChanged}" Foreground="#AAA" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Refresh status" Command="{Binding RefreshStatusCommand}" />
                                <Button Content="Change labels" Command="{Binding ChangeLabelsCommand}"
                                        ToolTip.Tip="Re-read the roll after swapping labels" />
                            </StackPanel>

                            <Separator />
                            <TextBlock Text="Print" FontWeight="Bold" Foreground="#CCC" />
                            <Grid ColumnDefinitions="90,*" Margin="0,2">
                                <TextBlock Text="Density" Foreground="#888" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Slider Width="150" Minimum="{Binding DensityMin}" Maximum="{Binding DensityMax}"
                                            Value="{Binding Density}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                    <TextBlock Text="{Binding Density, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Foreground="#AAA" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="90,*" Margin="0,2">
                                <TextBlock Text="Label type" Foreground="#888" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding LabelTypes}" SelectedItem="{Binding SelectedLabelType}" />
                            </Grid>
                            <Grid ColumnDefinitions="90,*" Margin="0,2">
                                <TextBlock Text="Copies" Foreground="#888" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Value="{Binding Copies}" Minimum="1" FormatString="0" />
                            </Grid>
                            <Grid ColumnDefinitions="90,*" Margin="0,2">
                                <TextBlock Text="Offset X px" Foreground="#888" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Value="{Binding OffsetX}" FormatString="0" />
                            </Grid>
                            <Grid ColumnDefinitions="90,*" Margin="0,2">
                                <TextBlock Text="Offset Y px" Foreground="#888" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Value="{Binding OffsetY}" FormatString="0" />
                            </Grid>
                            <Button Content="Print" Command="{Binding PrintCommand}" HorizontalAlignment="Stretch" Margin="0,6" />

                            <TextBlock Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}" Foreground="#8AC" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

    </DockPanel>

</Window>
