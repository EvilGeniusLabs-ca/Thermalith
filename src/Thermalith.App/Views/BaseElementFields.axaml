<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ed="clr-namespace:Thermalith.App.ViewModels.Editors"
             xmlns:vm="clr-namespace:Thermalith.App.ViewModels"
             x:Class="Thermalith.App.Views.BaseElementFields"
             x:DataType="ed:ElementEditorViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.lbl">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <!-- A single label column width (90) keeps the Name / X / W / Rotation field left edges aligned,
         and matches the per-editor inspector rows so labels never clip (e.g. "Line spacing"). -->
    <StackPanel Spacing="3">
        <TextBlock Text="{Binding TypeLabel}" FontWeight="Bold" Margin="0,0,0,2" />

        <Grid ColumnDefinitions="90,*" Margin="0,1">
            <TextBlock Classes="lbl" Text="Name" />
            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <TextBlock Classes="section" Text="Position &amp; size" />

        <!-- Decimal-mm positioning (0.5-mm spinner steps). X/Y allow negatives so elements can be
             positioned off the canvas edge (bleed model); W/H stay >= 1. -->
        <Grid ColumnDefinitions="90,*,22,*" Margin="0,1">
            <TextBlock Classes="lbl" Text="X" />
            <NumericUpDown Grid.Column="1" Value="{Binding X, Converter={StaticResource Nz}}" FormatString="0.#" Increment="0.5" />
            <TextBlock Classes="lbl" Grid.Column="2" Text="Y" Margin="6,0,4,0" />
            <NumericUpDown Grid.Column="3" Value="{Binding Y, Converter={StaticResource Nz}}" FormatString="0.#" Increment="0.5" />
        </Grid>

        <Grid ColumnDefinitions="90,*,22,*" Margin="0,1">
            <TextBlock Classes="lbl" Text="W" />
            <NumericUpDown Grid.Column="1" Value="{Binding W, Converter={StaticResource Nz}}" Minimum="1" FormatString="0.#" Increment="0.5" />
            <TextBlock Classes="lbl" Grid.Column="2" Text="H" Margin="6,0,4,0" />
            <NumericUpDown Grid.Column="3" Value="{Binding H, Converter={StaticResource Nz}}" Minimum="1" FormatString="0.#" Increment="0.5" />
        </Grid>

        <Grid ColumnDefinitions="90,*" Margin="0,1">
            <TextBlock Classes="lbl" Text="Rotation" />
            <NumericUpDown Grid.Column="1" Value="{Binding Rotation, Converter={StaticResource Nz}}" Minimum="0" Maximum="360" FormatString="0" />
        </Grid>

        <TextBlock Classes="section" Text="Alignment" />

        <!-- Horizontal align · vertical align · visibility/lock — all on one row. -->
        <StackPanel Orientation="Horizontal" Spacing="2">
            <ToggleButton Classes="icon" ToolTip.Tip="Align left" IsChecked="{Binding JustifyH, Converter={StaticResource Eq}, ConverterParameter=left}"><Path Classes="icon" Data="{StaticResource IconAlignLeft}" /></ToggleButton>
            <ToggleButton Classes="icon" ToolTip.Tip="Align center" IsChecked="{Binding JustifyH, Converter={StaticResource Eq}, ConverterParameter=center}"><Path Classes="icon" Data="{StaticResource IconAlignCenter}" /></ToggleButton>
            <ToggleButton Classes="icon" ToolTip.Tip="Align right" IsChecked="{Binding JustifyH, Converter={StaticResource Eq}, ConverterParameter=right}"><Path Classes="icon" Data="{StaticResource IconAlignRight}" /></ToggleButton>
            <ToggleButton Classes="icon" ToolTip.Tip="Justify" IsChecked="{Binding JustifyH, Converter={StaticResource Eq}, ConverterParameter=justify}"><Path Classes="icon" Data="{StaticResource IconAlignJustify}" /></ToggleButton>
            <Rectangle Width="1" Fill="{DynamicResource DividerWeak}" Margin="3,3" />
            <ToggleButton Classes="icon" ToolTip.Tip="Align top" IsChecked="{Binding JustifyV, Converter={StaticResource Eq}, ConverterParameter=top}"><Path Classes="icon" Data="{StaticResource IconAlignTop}" /></ToggleButton>
            <ToggleButton Classes="icon" ToolTip.Tip="Align middle" IsChecked="{Binding JustifyV, Converter={StaticResource Eq}, ConverterParameter=middle}"><Path Classes="icon" Data="{StaticResource IconAlignMiddle}" /></ToggleButton>
            <ToggleButton Classes="icon" ToolTip.Tip="Align bottom" IsChecked="{Binding JustifyV, Converter={StaticResource Eq}, ConverterParameter=bottom}"><Path Classes="icon" Data="{StaticResource IconAlignBottom}" /></ToggleButton>
            <Rectangle Width="1" Fill="{DynamicResource DividerWeak}" Margin="3,3" />
            <ToggleButton Classes="icon" ToolTip.Tip="Visible" IsChecked="{Binding Visible}"><Path Classes="icon" Data="{StaticResource IconEye}" /></ToggleButton>
            <ToggleButton Classes="icon" ToolTip.Tip="Locked" IsChecked="{Binding Locked}"><Path Classes="icon" Data="{StaticResource IconLock}" /></ToggleButton>
        </StackPanel>

        <!-- Distinct from the self-alignment row above: these centre the element ON THE LABEL. -->
        <TextBlock Classes="section" Text="Form alignment" />
        <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Content="Center H" ToolTip.Tip="Center horizontally on the label"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CenterOnLabelHCommand}" />
            <Button Content="Center V" ToolTip.Tip="Center vertically on the label"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CenterOnLabelVCommand}" />
        </StackPanel>

        <Separator Margin="0,2" />
    </StackPanel>

</UserControl>
