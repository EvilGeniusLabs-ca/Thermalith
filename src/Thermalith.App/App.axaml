<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Thermalith.App.Converters"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Thermalith.App.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <conv:EqualityConverter x:Key="Eq" />
        <conv:BoolToBrushConverter x:Key="ConnDot" TrueBrush="#3FB950" FalseBrush="#555" />
        <conv:BoolToCursorConverter x:Key="BusyCursor" />

        <!-- Line-art icons (stroked Paths, scaled to fit). Coordinates in a ~12-unit box. -->
        <StreamGeometry x:Key="IconAlignLeft">M0,0 H11 M0,4 H7 M0,8 H12</StreamGeometry>
        <StreamGeometry x:Key="IconAlignCenter">M2,0 H10 M4,4 H8 M0,8 H12</StreamGeometry>
        <StreamGeometry x:Key="IconAlignRight">M1,0 H12 M5,4 H12 M0,8 H12</StreamGeometry>
        <StreamGeometry x:Key="IconAlignJustify">M0,0 H12 M0,4 H12 M0,8 H12</StreamGeometry>
        <StreamGeometry x:Key="IconAlignTop">M0,0 H12 M3,2 V11 M9,2 V11</StreamGeometry>
        <StreamGeometry x:Key="IconAlignMiddle">M0,5 H12 M3,0 V11 M9,0 V11</StreamGeometry>
        <StreamGeometry x:Key="IconAlignBottom">M0,11 H12 M3,0 V9 M9,0 V9</StreamGeometry>
        <StreamGeometry x:Key="IconEye">M0,5 C3,0 9,0 12,5 C9,10 3,10 0,5 Z M7.8,5 A1.8,1.8 0 1 1 4.2,5 A1.8,1.8 0 1 1 7.8,5 Z</StreamGeometry>
        <StreamGeometry x:Key="IconLock">M2,5 H10 V11 H2 Z M3.5,5 V3.2 A2.5,2.5 0 0 1 8.5,3.2 V5</StreamGeometry>
        <StreamGeometry x:Key="IconText">M0,0 H10 M5,0 V11</StreamGeometry>
        <StreamGeometry x:Key="IconBarcode">M0,0 V11 M2,0 V11 M3,0 V11 M5,0 V11 M6,0 V11 M8,0 V11 M9,0 V11 M11,0 V11</StreamGeometry>
        <StreamGeometry x:Key="IconQr">M0,0 H4 V4 H0 Z M7,0 H11 V4 H7 Z M0,7 H4 V11 H0 Z M7,7 H9 V9 H7 Z M10,10 H11 V11 H10 Z</StreamGeometry>
        <StreamGeometry x:Key="IconSerial">M2,0 V11 M6,0 V11 M0,3 H8 M0,8 H8</StreamGeometry>
        <StreamGeometry x:Key="IconDate">M0,1 H12 V11 H0 Z M0,4 H12 M3,0 V2 M9,0 V2</StreamGeometry>
        <StreamGeometry x:Key="IconShape">M0,0 H11 V11 H0 Z</StreamGeometry>
        <StreamGeometry x:Key="IconImage">M0,1 H12 V11 H0 Z M3.5,4 A1,1 0 1 1 3.49,4 M0,11 L4,6 L7,9 L10,5 L12,7</StreamGeometry>
        <StreamGeometry x:Key="IconTable">M0,1 H12 V11 H0 Z M0,4.3 H12 M0,7.6 H12 M4,1 V11 M8,1 V11</StreamGeometry>
        <!-- Mirror (vertical axis) + flip (horizontal axis), hand-drawn until the full MDI migration. -->
        <StreamGeometry x:Key="IconMirror">M6,0 V12 M4.5,3 L1,6 L4.5,9 Z M7.5,3 L11,6 L7.5,9 Z</StreamGeometry>
        <StreamGeometry x:Key="IconFlip">M0,6 H12 M3,4.5 L6,1 L9,4.5 Z M3,7.5 L6,11 L9,7.5 Z</StreamGeometry>
    </Application.Resources>

    <Application.Styles>
        <!-- Avalonia's built-in control theme. "Default" follows the OS light/dark setting. -->
        <FluentTheme />

        <!-- Material Design Icons (Pictogrammers) — project icon set, used via <mi:MaterialIcon Kind="…" />. -->
        <mi:MaterialIconStyles />

        <!-- Stroked icon glyph used inside icon buttons. -->
        <Style Selector="Path.icon">
            <Setter Property="Stroke" Value="#D0D0D0" />
            <Setter Property="StrokeThickness" Value="1.3" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
        </Style>

        <!-- Compact square icon toggle button (justify / visible / lock / B-I-U). -->
        <Style Selector="ToggleButton.icon">
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Compact square icon button (command, not toggle) — matches ToggleButton.icon sizing. -->
        <Style Selector="Button.icon">
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Insert palette button: icon to the left of the label, full-width. -->
        <Style Selector="Button.insert">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="2" />
        </Style>
    </Application.Styles>

</Application>
